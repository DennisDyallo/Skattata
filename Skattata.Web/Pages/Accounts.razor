@page "/accounts"
@using Skattata.Web.Services
@using Skattata.Core
@inject SieFileService SieService
@implements IDisposable

<PageTitle>Chart of Accounts</PageTitle>

<h1>Chart of Accounts</h1>

@if (SieService.CurrentDocument == null)
{
    <div class="alert alert-warning" role="alert">
        No SIE file loaded. Please <a href="/upload" class="alert-link">upload a file</a> first.
    </div>
}
else
{
    var accounts = SieService.CurrentDocument.Accounts;

    <div class="mb-3">
        <p class="text-muted">Showing @accounts.Count account(s)</p>
    </div>

    @if (accounts.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No accounts found in this SIE file.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Account Number</th>
                        <th>Account Name</th>
                        <th>Type</th>
                        <th>Unit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kvp in accounts.OrderBy(a => a.Key))
                    {
                        var account = kvp.Value;
                        <tr>
                            <td><code>@account.AccountId</code></td>
                            <td>@account.Name</td>
                            <td>
                                @if (!string.IsNullOrEmpty(account.Type))
                                {
                                    <span class="badge bg-secondary">@account.Type</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(account.Unit))
                                {
                                    @account.Unit
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    protected override void OnInitialized()
    {
        SieService.OnDocumentChanged += StateHasChanged;
    }

    public void Dispose()
    {
        SieService.OnDocumentChanged -= StateHasChanged;
    }
}
