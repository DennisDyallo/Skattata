@page "/balance-sheet"
@using Skattata.Web.Services
@inject BalanceSheetService BalanceSheetService
@inject SieFileService SieFileService
@implements IDisposable

<PageTitle>Balance Sheet</PageTitle>

<h1>Balance Sheet</h1>
<p class="text-muted">Balansräkning - Aggregated from all uploaded SIE files</p>

@if (SieFileService.AllDocuments.Count == 0)
{
    <div class="alert alert-warning" role="alert">
        No SIE files loaded. Please <a href="/upload" class="alert-link">upload files</a> to view the balance sheet.
    </div>
}
else
{
    <div class="mb-3">
        <p>
            <strong>Generated:</strong> @balanceSheet.GeneratedAt.ToString("yyyy-MM-dd HH:mm:ss") |
            <strong>Documents:</strong> @balanceSheet.DocumentCount
        </p>
        <button class="btn btn-primary btn-sm" @onclick="RefreshBalanceSheetAsync">
            <span class="oi oi-reload me-1"></span>Refresh
        </button>
        <a href="/upload" class="btn btn-secondary btn-sm ms-2">
            <span class="oi oi-cloud-upload me-1"></span>Upload More Files
        </a>
    </div>

    @if (!balanceSheet.IsBalanced)
    {
        <div class="alert alert-warning" role="alert">
            <strong>Warning:</strong> Balance sheet does not balance.
            Total Assets (@balanceSheet.TotalAssets.ToString("N2")) ≠
            Liabilities + Equity (@balanceSheet.LiabilitiesAndEquity.ToString("N2"))
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Assets (Tillgångar)</h5>
                </div>
                <div class="card-body p-0">
                    @if (balanceSheet.Assets.Any())
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Account</th>
                                    <th>Name</th>
                                    <th class="text-end">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in balanceSheet.Assets.Where(a => a.CurrentBalance != 0).OrderBy(a => a.AccountId))
                                {
                                    <tr>
                                        <td><code>@account.AccountId</code></td>
                                        <td>@account.Name</td>
                                        <td class="text-end">@account.CurrentBalance.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td colspan="2"><strong>Total Assets</strong></td>
                                    <td class="text-end"><strong>@balanceSheet.TotalAssets.ToString("N2")</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="p-3 text-muted">No asset accounts found</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Liabilities (Skulder)</h5>
                </div>
                <div class="card-body p-0">
                    @if (balanceSheet.Liabilities.Any())
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Account</th>
                                    <th>Name</th>
                                    <th class="text-end">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in balanceSheet.Liabilities.Where(a => a.CurrentBalance != 0).OrderBy(a => a.AccountId))
                                {
                                    <tr>
                                        <td><code>@account.AccountId</code></td>
                                        <td>@account.Name</td>
                                        <td class="text-end">@account.CurrentBalance.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td colspan="2"><strong>Total Liabilities</strong></td>
                                    <td class="text-end"><strong>@balanceSheet.TotalLiabilities.ToString("N2")</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="p-3 text-muted">No liability accounts found</div>
                    }
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Equity (Eget Kapital)</h5>
                </div>
                <div class="card-body p-0">
                    @if (balanceSheet.Equity.Any())
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Account</th>
                                    <th>Name</th>
                                    <th class="text-end">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in balanceSheet.Equity.Where(a => a.CurrentBalance != 0).OrderBy(a => a.AccountId))
                                {
                                    <tr>
                                        <td><code>@account.AccountId</code></td>
                                        <td>@account.Name</td>
                                        <td class="text-end">@account.CurrentBalance.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td colspan="2"><strong>Total Equity</strong></td>
                                    <td class="text-end"><strong>@balanceSheet.TotalEquity.ToString("N2")</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="p-3 text-muted">No equity accounts found</div>
                    }
                </div>
            </div>

            <div class="card border-dark">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Total Liabilities + Equity</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-5">Total:</span>
                        <span class="fs-4 fw-bold">@balanceSheet.LiabilitiesAndEquity.ToString("N2")</span>
                    </div>
                    @if (balanceSheet.IsBalanced)
                    {
                        <div class="mt-2 text-success">
                            <span class="oi oi-check me-1"></span>Balance Sheet is balanced
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private BalanceSheetReport balanceSheet = new();

    protected override async Task OnInitializedAsync()
    {
        await RefreshBalanceSheetAsync();
        SieFileService.OnDocumentChanged += OnDocumentChanged;
    }

    private async void OnDocumentChanged()
    {
        await RefreshBalanceSheetAsync();
        StateHasChanged();
    }

    private async Task RefreshBalanceSheetAsync()
    {
        balanceSheet = await BalanceSheetService.CalculateBalanceSheetAsync();
    }

    public void Dispose()
    {
        SieFileService.OnDocumentChanged -= OnDocumentChanged;
    }
}
