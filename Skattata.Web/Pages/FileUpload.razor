@page "/upload"
@using Skattata.Web.Services
@inject SieFileService SieService

<PageTitle>Upload SIE File</PageTitle>

<h1>Upload SIE File</h1>

<p>Select a SIE file (.se, .si, or .sie) to parse and view accounting data.</p>

<div class="mb-3">
    <InputFile OnChange="@HandleFileSelected" accept=".se,.si,.sie" class="form-control" />
</div>

@if (isLoading)
{
    <div class="alert alert-info">
        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
        Loading and parsing file...
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        <strong>Error:</strong> @errorMessage
    </div>
}

@if (successMessage != null)
{
    <div class="alert alert-success" role="alert">
        <strong>Success!</strong> @successMessage
        <div class="mt-2">
            <a href="/accounts" class="btn btn-primary btn-sm">View Accounts</a>
            <a href="/vouchers" class="btn btn-primary btn-sm ms-2">View Vouchers</a>
        </div>
    </div>
}

@if (SieService.CurrentDocument != null)
{
    var doc = SieService.CurrentDocument;
    <div class="card mt-4">
        <div class="card-header">
            <h5>Document Information</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Company:</dt>
                <dd class="col-sm-9">@doc.CompanyName (@doc.OrganizationNumber)</dd>

                <dt class="col-sm-3">Format:</dt>
                <dd class="col-sm-9">@doc.Format</dd>

                <dt class="col-sm-3">Accounts:</dt>
                <dd class="col-sm-9">@doc.Accounts.Count</dd>

                <dt class="col-sm-3">Vouchers:</dt>
                <dd class="col-sm-9">@doc.Vouchers.Count</dd>

                @if (doc.BookingYears.Any())
                {
                    <dt class="col-sm-3">Fiscal Years:</dt>
                    <dd class="col-sm-9">@doc.BookingYears.Count</dd>
                }
            </dl>
        </div>
    </div>
}

@code {
    private bool isLoading = false;
    private string? errorMessage = null;
    private string? successMessage = null;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            var file = e.File;

            // Limit file size to 50MB
            const long maxFileSize = 50 * 1024 * 1024;

            if (file.Size > maxFileSize)
            {
                errorMessage = "File is too large. Maximum size is 50MB.";
                return;
            }

            using var stream = file.OpenReadStream(maxFileSize);
            var result = await SieService.LoadFileAsync(stream, file.Name);

            if (result.Success)
            {
                successMessage = $"Successfully parsed {file.Name}";
            }
            else
            {
                errorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading file: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
