@page "/"

<PageTitle>Skattata - SIE File Viewer</PageTitle>

<h1>Skattata</h1>
<p class="lead">Swedish SIE Accounting File Viewer</p>

<div class="row mt-4">
    <div class="col-md-8">
        <h3>Welcome to Skattata</h3>
        <p>
            Skattata is a web-based viewer for Swedish SIE (Standard Import Export) accounting files.
            Upload and view SIE files to explore accounting data including charts of accounts and vouchers.
        </p>

        <h4>Supported Formats</h4>
        <ul>
            <li><strong>SIE 4</strong> - Tag-based text format</li>
            <li><strong>SIE 5</strong> - Modern XML format</li>
        </ul>

        <h4>Features</h4>
        <ul>
            <li>Upload and parse SIE files (.se, .si, .sie)</li>
            <li>View chart of accounts</li>
            <li>Browse accounting vouchers and transactions</li>
            <li>Support for multi-dimensional accounting (projects, cost centers)</li>
        </ul>

        <div class="mt-4">
            <a href="/upload" class="btn btn-primary btn-lg">
                <span class="oi oi-cloud-upload me-2"></span>
                Get Started - Upload a File
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Quick Links</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <a href="/upload" class="text-decoration-none">
                            <span class="oi oi-cloud-upload me-2"></span>Upload File
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="/add-voucher" class="text-decoration-none">
                            <span class="oi oi-plus me-2"></span>Add Voucher
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="/balance-sheet" class="text-decoration-none">
                            <span class="oi oi-bar-chart me-2"></span>Balance Sheet
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="/accounts" class="text-decoration-none">
                            <span class="oi oi-spreadsheet me-2"></span>View Accounts
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="/vouchers" class="text-decoration-none">
                            <span class="oi oi-document me-2"></span>View Vouchers
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">About SIE</h5>
            </div>
            <div class="card-body">
                <p class="small">
                    SIE (Standard Import Export) is the standard format for exchanging
                    accounting data between Swedish accounting systems.
                </p>
            </div>
        </div>
    </div>
</div>
